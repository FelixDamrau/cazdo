Set Theme "Catppuccin Mocha"
Set FontSize 20
Set Width 1400
Set Height 900
Set Framerate 30
Set Padding 24
Set TypingSpeed 0.1s

Hide
Type "export PATH=.:$PATH"
Enter
Ctrl+L
Show 

Type "cazdo"
Sleep 0.5s
Enter
Sleep 2s

Type "j"
Sleep 1.5s
Type "j"
Sleep 1.5s
Type "j"
Sleep 1.2s
Type "/"
Sleep 0.5s
Type "feature"
Sleep 1s
Enter
Sleep 1s
Type "j"
Sleep 1.5s
Type "t"
Sleep 1s
Type "j"
Sleep 1.5s

Type "q"
Sleep 1s
